---
import { content } from '../data/content';

const { brand, contact, footer } = content;
---

<!-- ============================ FOOTER ============================ -->
<footer class="footer">
  <div class="shell">
    <div class="footer-top">
      <div>
        <a class="logo" href="#top" aria-label={brand.homeLabel}>
          <img class="logo-image" src={brand.logoSrc} width={brand.logoWidth} height={brand.logoHeight} alt="" loading="lazy" decoding="async" />
        </a>
        <div class="footer-tag">{brand.footerTag}</div>
      </div>
      <nav class="footer-nav" aria-label="Pied de page">
        {footer.columns.map((column) => (
          <div class="footer-col">
            <h4>{column.title}</h4>
            {column.links.map((link) => <a href={link.href}>{link.label}</a>)}
          </div>
        ))}
      </nav>
    </div>
    <div class="footer-bottom">
      <div class="copy">{footer.copyright}</div>
      <div class="footer-social">
        <a href="#" aria-label={footer.socialLabels.linkedIn}><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5A2.5 2.5 0 002.5 6a2.5 2.5 0 002.48 2.5A2.5 2.5 0 007.5 6 2.5 2.5 0 004.98 3.5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3 0-3-1.8-3s-2.1 1.4-2.1 2.9V21h-4z"/></svg></a>
        <a href={`mailto:${contact.details.email}`} aria-label={footer.socialLabels.email}><svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.7"/><path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="1.7"/></svg></a>
        <a href={`tel:${contact.details.phoneHref}`} aria-label={footer.socialLabels.phone}><svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 4h3l2 5-2 1.5a12 12 0 005.5 5.5L18 14l-1.5-2L20 9" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" transform="translate(-1 0)"/></svg></a>
      </div>
    </div>
  </div>
</footer>

<!-- WhatsApp FAB -->
<a class="wa-fab" href={`https://wa.me/${contact.details.phoneHref.replace('+', '')}`} target="_blank" rel="noopener" aria-label={footer.socialLabels.whatsApp}>
  <svg viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 3C9.4 3 4 8.4 4 15c0 2.1.6 4.1 1.6 5.9L4 29l8.3-1.6c1.7.9 3.6 1.4 5.7 1.4 6.6 0 12-5.4 12-12S22.6 3 16 3zm0 21.8c-1.8 0-3.5-.5-5-1.4l-.4-.2-4.9 1 1-4.8-.3-.4A9.8 9.8 0 016.2 15 9.8 9.8 0 0116 5.2 9.8 9.8 0 0125.8 15 9.8 9.8 0 0116 24.8zm5.4-7.3c-.3-.1-1.8-.9-2-1-.3-.1-.5-.1-.7.1s-.8 1-.9 1.1c-.2.2-.3.2-.6.1-1.8-.9-3-1.6-4.2-3.6-.3-.5.3-.5.9-1.6.1-.2 0-.4 0-.5l-.9-2.2c-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-1 1-1.3 2.2-1.3 3.6 0 .2 0 .5.1.7.4 1.3 1.3 2.6 1.5 2.8.2.2 2.6 4 6.4 5.5 2.4.9 3.3.9 4.4.8.7-.1 1.8-.7 2.1-1.5.3-.7.3-1.4.2-1.5-.1-.2-.3-.2-.6-.4z"/></svg>
</a>
