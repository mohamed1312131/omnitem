---
import { content } from '../data/content';

const { contact } = content;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<!-- ============================ CONTACT ============================ -->
<section class="sec contact" id="contact" data-screen-label="Contact">
  <canvas id="contact-mesh" aria-hidden="true"></canvas>
  <div class="shell">
    <div class="contact-grid">
      <div class="contact-intro r">
        <span class="eyebrow on-dark">{contact.eyebrow}</span>
        <h2 class="h2" style="margin-top:18px">{contact.title}</h2>
        <p class="lead" style="margin-top:20px">{contact.lead}</p>
        <div class="contact-details">
          <div class="cd-row">
            <svg class="ic" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="1.5"/></svg>
            <div><div class="k">{contact.details.emailLabel}</div><a class="v" href={`mailto:${contact.details.email}`}>{contact.details.email}</a></div>
          </div>
          <div class="cd-row">
            <svg class="ic" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 4h3l2 5-2 1.5a12 12 0 005.5 5.5L20 14l-1.5-2L23 9" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" transform="translate(-2 0)"/></svg>
            <div><div class="k">{contact.details.phoneLabel}</div><a class="v" href={`tel:${contact.details.phoneHref}`}>{contact.details.phoneDisplay}</a></div>
          </div>
          <div class="cd-row">
            <svg class="ic" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-5.5 7-11a7 7 0 10-14 0c0 5.5 7 11 7 11z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
            <div><div class="k">{contact.details.areaLabel}</div><div class="v">{contact.details.area}</div></div>
          </div>
        </div>
      </div>

      <div class="form-card r s2">
        <form id="contactForm" novalidate>
          <div class="grid2">
            <div class="field"><label for="f-nom">{contact.form.name}</label><input id="f-nom" name="nom" type="text" placeholder={contact.form.namePlaceholder} required /></div>
            <div class="field"><label for="f-soc">{contact.form.company}</label><input id="f-soc" name="societe" type="text" placeholder={contact.form.companyPlaceholder} /></div>
          </div>
          <div class="grid2">
            <div class="field"><label for="f-email">{contact.form.email}</label><input id="f-email" name="email" type="email" placeholder={contact.form.emailPlaceholder} required /></div>
            <div class="field"><label for="f-tel">{contact.form.phone}</label><input id="f-tel" name="telephone" type="tel" placeholder={contact.form.phonePlaceholder} /></div>
          </div>
          <div class="field"><label for="f-msg">{contact.form.message}</label><textarea id="f-msg" name="message" placeholder={contact.form.messagePlaceholder} required></textarea></div>
          <div class="hp-field" aria-hidden="true">
            <label for="f-entreprise-url">Site web</label>
            <input id="f-entreprise-url" name="entreprise_url" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <div class="turnstile-wrap">
            <div class="cf-turnstile" data-sitekey={turnstileSiteKey}></div>
          </div>
          <button type="submit" class="btn btn-primary">{contact.form.submit} <span class="arrow">→</span></button>
          <p class="form-error" id="formError" role="alert" hidden></p>
          <p class="form-note">{contact.form.note}</p>
        </form>
        <div class="form-success" id="formSuccess">
          <svg class="ok" viewBox="0 0 56 56" fill="none" aria-hidden="true"><circle cx="28" cy="28" r="26" stroke="currentColor" stroke-width="2"/><path d="M17 28.5l7 7L40 20" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <h3>{contact.form.successTitle}</h3>
          <p>{contact.form.successText}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
