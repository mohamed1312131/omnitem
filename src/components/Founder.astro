---
import { content } from '../data/content';

const { founder } = content;
---

<!-- ============================ FOUNDER ============================ -->
<section class="sec founder" id="founder" data-screen-label="Fondateur">
  <div class="shell">
    <div class="founder-grid">
      <div class="founder-photo r">
        <canvas class="ph-mesh" aria-hidden="true"></canvas>
        <div class="ph-initials">{founder.initials}</div>
      </div>
      <div class="founder-body r s2">
        <span class="section-num">{founder.sectionNum}</span>
        <h2 class="h2" style="margin-top:16px">{founder.name}</h2>
        <div class="founder-role">{founder.role}</div>
        <p>{founder.paragraphs[0]}</p>
        <p>{founder.paragraphs[1]}</p>
        <div class="founder-creds">
          {founder.credentials.map((credential) => <span class="cred"><b>{credential.strong}</b>{credential.text}</span>)}
        </div>
      </div>
    </div>
  </div>
</section>
